# --- Vercel Deployment Environment Variables ---

# Gemini API Key (Required for AI generation)
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Node Environment
NODE_ENV=production

# --- Optional: Database ---
# Note: SQLite (better-sqlite3) is used by default.
# On Vercel, it uses /tmp/questions.db which is temporary.
# For persistent storage, consider using a remote database.
